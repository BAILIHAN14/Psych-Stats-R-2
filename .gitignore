# ============================================
# 1. Quarto 渲染输出和缓存
# ============================================
_book/           # 全书渲染后的HTML/PDF/EPUB输出目录，由CI或本地发布，不入库
_site/           # 网站模式渲染输出目录
_quarto.yml      # 这是配置文件
.freeze/         
.quarto/         

# ============================================
# 2. R 会话临时文件
# ============================================
.Rproj.user/     # RStudio 项目用户
.Rhistory        # R 控制台历史命令
.RData           # R 工作空间镜像文件
.Rapp.history    # R.app 历史
*.Rproj          # Rproj文件

# *.Rproj

# ============================================
# 3. R 包管理
# ============================================
renv/library/    
renv/local/
renv/cellar/
renv/lock/
renv/python/
renv/sandbox/
renv/staging/

# ============================================
# 4. LaTeX / PDF 编译中间文件
# ============================================
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.xdv
*.toc
*.lof
*.lot

# ============================================
# 5. 操作系统生成的文件
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
# Linux
.directory
*~

# ============================================
# 6. 编辑器/IDE 配置
# ============================================
.vscode/         # VS Code 设置（除非你要共享工作区配置，否则忽略）
.idea/           # JetBrains 系列 IDE（如 RStudio 外的 PyCharm 等）
*.swp            # Vim 交换文件
*.swo            # Vim 未保存文件
*~               # Emacs 备份文件

# ============================================
# 7. 敏感信息或环境变量
# ============================================
.env             # API密钥等
*.htpasswd

# ============================================
# 8. 临时或生成的大文件
# ============================================
*.zip            # 除非你是故意上传的数据集zip
*.tar.gz
*.rds            # 如果你单独生成过R二进制大文件，可以忽略，否则自己决定
*.feather
*.parquet
# 注意：data/ 和 images/ 目录不应被整体忽略，它们是项目所需资源