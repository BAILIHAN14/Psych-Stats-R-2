
* text=auto

# 将数据文件和图片标记为 vendored，不计入语言统计
data/*.sav linguist-vendored
data/*.xlsx linguist-vendored
docs/images/*.png linguist-vendored
docs/images/*.jpg linguist-vendored

# 将 HTML 标记为文档而非代码
*.html linguist-documentation

# R 和 Rmd 明确为源代码
*.R linguist-language=R
*.Rmd linguist-language=RMarkdown
